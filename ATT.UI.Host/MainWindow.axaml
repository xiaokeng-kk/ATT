<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ATT.UI.Host.ViewModels"
        xmlns:views="using:ATT.UI.Host.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="ATT.UI.Host.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}">

  <Grid>
    <!--
      Mode-based view switching.
      Only ONE view is visible at a time — the other is collapsed (no layout space).
      IsVisible = false in Avalonia means Visibility.Collapsed.
    -->
    <views:DeviceSetupView IsVisible="{Binding IsSetupMode}"
                           DataContext="{Binding DeviceSetup}" />

    <views:RuntimeView IsVisible="{Binding IsRuntimeMode}"
                        DataContext="{Binding Runtime}" />
  </Grid>

</Window>
