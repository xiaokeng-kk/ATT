<Window x:Class="ATT.UI.Host.MainWindow" xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:ATT.UI.Host.Views" xmlns:vm="using:ATT.UI.Host.ViewModels"
        Title="{Binding Title}"
        d:DesignHeight="700" d:DesignWidth="1200"
        x:DataType="vm:MainWindowViewModel" mc:Ignorable="d">

    <Grid>
        <!--
            Mode-based view switching.
            Only ONE view is visible at a time — the other is collapsed (no layout space).
            IsVisible = false in Avalonia means Visibility.Collapsed.
            IMPORTANT: IsVisible binds to the Window's DataContext (MainWindowViewModel)
            via RelativeSource, because each child view overrides its own DataContext
            with a sub-ViewModel (DeviceSetup / Runtime) that does NOT have
            IsSetupMode/IsRuntimeMode properties.
        -->
        <views:DeviceSetupView DataContext="{Binding DeviceSetup}"
							   IsVisible="{Binding $parent[Window].DataContext.IsSetupMode}" />

        <views:RuntimeView DataContext="{Binding Runtime}"
						   IsVisible="{Binding $parent[Window].DataContext.IsRuntimeMode}" />
    </Grid>

</Window>
